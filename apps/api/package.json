{
  "name": "@fatec-study/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/src/main.js",
    "prebuild": "prisma generate",
    "build": "nest build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:prod": "node dist/prisma/seed.js",
    "import:fatec": "tsx src/scripts/import-fatec.ts",
    "import:fatec:prod": "node dist/src/scripts/import-fatec.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@prisma/client": "^6.16.0",
    "axios": "^1.12.0",
    "cheerio": "^1.1.2",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^24.5.0",
    "@types/pdf-parse": "^1.1.5",
    "eslint": "^9.35.0",
    "prisma": "^6.16.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.44.0",
    "vitest": "^3.2.0"
  }
}
